def analyze_selected(b):
    with analysis_output:
        clear_output(wait=True)
        
        selected = [name for name, cb in group_checkboxes.items() if cb.value]
        
        if not selected:
            print("⚠️ No groups selected. Click 'RESET TO DEFAULT' to see default matrix.")
            return
        
        threshold = threshold_slider.value
        
        print("="*60)
        print(f"📊 ANALYSIS: {', '.join(selected)}")
        print(f"⚙️ Patients must have at least {threshold} symptom(s) from selected groups")
        print("="*60 + "\n")
        
        # Collect all symptoms from selected groups
        all_symptoms = []
        for group in selected:
            all_symptoms.extend(symptom_groups[group])
        all_symptoms = list(set(all_symptoms))
        
        # Filter patients
        filtered_df = get_patients_with_symptoms(all_symptoms, threshold)
        
        if filtered_df is None or len(filtered_df) == 0:
            print(f"❌ No patients found with symptoms from: {', '.join(selected)}")
            print("   Try lowering the threshold or selecting different groups.")
            return
        
        print(f"👥 Patients found: {len(filtered_df)} out of {len(df)} ({len(filtered_df)/len(df)*100:.1f}%)\n")
        
        # Plot confusion matrix
        title = f"Confusion Matrix - Patients with {', '.join(selected)} symptoms"
        fig, acc, cm_sub = plot_confusion_matrix_with_interpretation(filtered_df, title, selected)
        
        if fig:
            fig.show()
            
            # Print interpretation for this subset
            print(f"\n📊 INTERPRETATION FOR THIS SUBSET:")
            print("-" * 50)
            
            for i, disease in enumerate(le.classes_):
                correct = cm_sub[i, i] if i < len(cm_sub) else 0
                total = cm_sub[i].sum() if i < len(cm_sub) else 0
                acc_class = correct / total if total > 0 else 0
                
                print(f"\n🔵 {disease.upper()}:")
                print(f"   ✅ Correct: {correct}/{total} ({acc_class:.1%})")
                
                # Find wrong predictions
                for j in range(n_classes):
                    if i != j and i < len(cm_sub) and j < len(cm_sub[i]) and cm_sub[i, j] > 0:
                        print(f"   ❌ {cm_sub[i, j]} patients wrongly predicted as {le.classes_[j]}")
            
            print(f"\n📈 Comparison with Overall Model:")
            print(f"   Overall Accuracy: {accuracy:.2%}")
            print(f"   Subset Accuracy: {acc:.2%}")
            print(f"   Difference: {(acc - accuracy):+.2%}")

def reset_to_default(b):
    with analysis_output:
        clear_output(wait=True)
        print("="*60)
