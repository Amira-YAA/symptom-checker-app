def compare_symptoms(b):
    with compare_output:
        clear_output(wait=True)
        
        disease1 = disease1_selector.value
        disease2 = disease2_selector.value
        
        # Get symptom frequencies for each disease
        data1 = df[df['diseases'] == disease1]
        data2 = df[df['diseases'] == disease2]
        
        freq1 = data1[symptom_cols].sum() / len(data1)
        freq2 = data2[symptom_cols].sum() / len(data2)
        
        # Calculate differences
        diff_df = pd.DataFrame({
            'symptom': symptom_cols,
            'disease1_freq': freq1.values,
            'disease2_freq': freq2.values,
            'difference': freq1.values - freq2.values,
            'abs_diff': np.abs(freq1.values - freq2.values)
        }).sort_values('abs_diff', ascending=False)
        
        print(f"\n📊 COMPARISON: {disease1.upper()} vs {disease2.upper()}")
        print("="*60)
        
        print(f"\n🔍 Top 10 Distinguishing Symptoms:")
        print(f"{'Symptom':<45} {disease1[:25]:<25} {disease2[:25]:<25} {'Difference':<12}")
        print("-"*110)
        
        for i, row in diff_df.head(10).iterrows():
            # Fix the formatting issue
            pct1 = f"{row['disease1_freq']:.1%}"
            pct2 = f"{row['disease2_freq']:.1%}"
            diff_pct = f"{row['difference']:+.1%}"
            print(f"{row['symptom'][:44]:<45} {pct1:<25} {pct2:<25} {diff_pct:<12}")
        
        # Create comparison bar chart
        top_diff = diff_df.head(15)
        
        fig = make_subplots(rows=1, cols=2,
                           subplot_titles=(f'Top Symptoms in {disease1}', 
                                          f'Top Symptoms in {disease2}'),
                           horizontal_spacing=0.2)
        
        # Disease 1 symptoms
        top1 = top_diff.nlargest(10, 'disease1_freq')
        fig.add_trace(
            go.Bar(x=top1['disease1_freq'].values, y=top1['symptom'].values,
                  orientation='h', marker_color='#FF6B6B',
                  text=[f'{v:.1%}' for v in top1['disease1_freq'].values],
                  textposition='outside'),
            row=1, col=1
        )
        
        # Disease 2 symptoms
        top2 = top_diff.nlargest(10, 'disease2_freq')
        fig.add_trace(
            go.Bar(x=top2['disease2_freq'].values, y=top2['symptom'].values,
                  orientation='h', marker_color='#4ECDC4',
                  text=[f'{v:.1%}' for v in top2['disease2_freq'].values],
                  textposition='outside'),
            row=1, col=2
        )
        
        fig.update_layout(height=600, showlegend=False,
                         title_text=f"Symptom Comparison: {disease1} vs {disease2}")
        fig.update_xaxes(title_text="Prevalence", row=1, col=1)
        fig.update_xaxes(title_text="Prevalence", row=1, col=2)
        
        fig.show()
        
        # Differential symptoms heatmap
        pivot_data = top_diff.set_index('symptom')[['disease1_freq', 'disease2_freq']].head(20)
        
        fig2 = go.Figure(data=go.Heatmap(
            z=pivot_data.values.T,
            x=pivot_data.index,
            y=[disease1, disease2],
            colorscale='RdYlGn',
            zmid=0,
            text=np.round(pivot_data.values.T * 100, 1),
            texttemplate='%{text}%',
            textfont={"size": 10}
        ))
        
        fig2.update_layout(
            title="Symptom Prevalence Comparison Heatmap",
            xaxis_title="Symptoms",
            yaxis_title="Disease",
            height=400
        )
        
        fig2.show()

compare_button.on_click(compare_symptoms)
