def get_patients_with_symptoms(symptom_list, threshold=1):
    """Get patients with at least 'threshold' symptoms from the list"""
    if not symptom_list:
        return None
    
    existing = [s for s in symptom_list if s in symptom_cols]
    if not existing:
        return None
    
    symptom_count = df[existing].sum(axis=1)
    return df[symptom_count >= threshold]

def plot_confusion_matrix_with_interpretation(data_subset, title, group_names):
    """Plot confusion matrix with interpretation for data subset"""
    if data_subset is None or len(data_subset) == 0:
        return None, 0
    
    X_sub = data_subset[symptom_cols]
    y_true = data_subset['diseases']
    y_true_encoded = le.transform(y_true)
    y_pred_sub = rf.predict(X_sub)
    
    acc = accuracy_score(y_true_encoded, y_pred_sub)
    cm_sub = confusion_matrix(y_true_encoded, y_pred_sub, labels=range(n_classes))
    
    fig = go.Figure(data=go.Heatmap(
        z=cm_sub,
        x=le.classes_,
        y=le.classes_,
        text=cm_sub,
        texttemplate='%{text}',
        textfont={"size": 14, "color": "white"},
        colorscale='Blues',
        showscale=True,
        colorbar_title="Number of Patients"
    ))
    
    fig.update_layout(
        title={
            'text': f'{title}<br><span style="font-size:12px">Rows: Actual | Columns: Predicted | Accuracy: {acc:.2%} | Patients: {len(data_subset)}</span>',
            'x': 0.5,
            'xanchor': 'center'
        },
        xaxis_title='<b>PREDICTED DISEASE</b>',
        yaxis_title='<b>ACTUAL DISEASE</b>',
        height=500,
        width=700
    )
    
    return fig, acc, cm_sub

