def update_explorer(change):
    with explorer_output:
        clear_output(wait=True)
        
        disease = disease_selector.value
        top_n = top_n_slider.value
        
        # Filter data
        if disease == 'All':
            plot_data = df
            title = "All Diseases"
        else:
            plot_data = df[df['diseases'] == disease]
            title = f"Disease: {disease}"
        
        # Calculate symptom frequencies
        symptom_freq = plot_data[symptom_cols].sum().sort_values(ascending=False)
        
        # Create separate figures instead of subplots to avoid type issues
        
        # Figure 1: Top symptoms bar chart
        fig1 = go.Figure()
        top_symptoms = symptom_freq.head(top_n)
        fig1.add_trace(go.Bar(
            x=top_symptoms.values, 
            y=top_symptoms.index,
            orientation='h', 
            marker_color='#667eea',
            text=top_symptoms.values, 
            textposition='outside'
        ))
        fig1.update_layout(
            title=f'Top {top_n} Symptoms - {title}',
            xaxis_title='Frequency',
            yaxis_title='Symptoms',
            height=500,
            margin=dict(l=0, r=0, t=40, b=0)
        )
        fig1.show()
        
        # Figure 2: Distribution histogram
        fig2 = go.Figure()
        fig2.add_trace(go.Histogram(
            x=symptom_freq.values, 
            nbinsx=30,
            marker_color='#764ba2'
        ))
        fig2.update_layout(
            title='Symptom Prevalence Distribution',
            xaxis_title='Symptom Frequency',
            yaxis_title='Count',
            height=400
        )
        fig2.show()
        
        # Figure 3: Disease distribution bar chart (instead of pie)
