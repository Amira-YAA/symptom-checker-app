def make_prediction(b):
    with prediction_result:
        clear_output(wait=True)
        
        # Get selected symptoms
        selected = [symptom for symptom, cb in all_symptom_checkboxes.items() if cb.value]
        
        if not selected:
            print("⚠️ Please select at least one symptom")
            return
        
        progress_bar.layout.visibility = 'visible'
        progress_bar.value = 0.5
        
        print(f"🔍 Analyzing {len(selected)} symptoms...\n")
        
        # Create feature vector
        feature_vector = pd.DataFrame(0, index=[0], columns=symptom_cols)
        for symptom in selected:
            if symptom in feature_vector.columns:
                feature_vector[symptom] = 1
        
        # Predict
        pred = rf.predict(feature_vector)[0]
        probs = rf.predict_proba(feature_vector)[0]
        predicted_disease = le.inverse_transform([pred])[0]
        
        progress_bar.value = 1.0
        
        # Display results
        print("="*60)
        print("🔮 PREDICTION RESULT")
        print("="*60)
        
        confidence = max(probs)
        if confidence > 0.8:
            emoji = "🎯"
            level = "HIGH"
        elif confidence > 0.6:
            emoji = "✅"
            level = "MEDIUM"
        else:
            emoji = "⚠️"
            level = "LOW"
        
        print(f"\n{emoji} Predicted Disease: {predicted_disease.upper()}")
        print(f"📊 Confidence: {level} ({confidence:.2%})")
        print(f"📋 Symptoms used: {len(selected)}\n")
        
        # Probability bars
        print("📈 Probability Distribution:")
        print("-" * 55)
        for i, disease in enumerate(le.classes_):
            bar_len = int(probs[i] * 35)
            bar = "█" * bar_len + "░" * (35 - bar_len)
            print(f"   {disease:25} |{bar}| {probs[i]:.1%}")
        print("-" * 55)
        
        # Simple bar chart
        fig, ax = plt.subplots(figsize=(8, 4))
        colors = ['#FF6B6B', '#4ECDC4', '#45B7D1']
        bars = ax.bar(le.classes_, probs, color=colors, edgecolor='black', linewidth=1)
        ax.set_ylabel('Probability')
        ax.set_title(f'Prediction: {predicted_disease.upper()}')
        ax.set_ylim(0, 1)
        
        for bar, prob in zip(bars, probs):
            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,
                   f'{prob:.1%}', ha='center', va='bottom', fontweight='bold')
        
        plt.tight_layout()
        plt.show()
        
        progress_bar.layout.visibility = 'hidden'
        progress_bar.value = 0

predict_btn.on_click(make_prediction)

