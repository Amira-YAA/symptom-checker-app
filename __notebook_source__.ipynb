            accuracy_class = correct / total if total > 0 else 0
            print(f"\n🔵 {disease.upper()}:")
            print(f"   ✅ Correct: {correct}/{total} ({accuracy_class:.1%})")
            
            # Find wrong predictions
            for j in range(n_classes):
                if i != j and cm[i, j] > 0:
                    print(f"   ❌ {cm[i, j]} patients wrongly predicted as {le.classes_[j]}")

