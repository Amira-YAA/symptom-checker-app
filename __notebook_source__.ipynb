# Output area
prediction_output = widgets.Output()

def predict_disease(b):
    with prediction_output:
        clear_output(wait=True)
        
        # Collect selected symptoms
        selected = [symptom for symptom, checkbox in all_checkboxes.items() if checkbox.value]
        
        if not selected:
            print("⚠️ Please select at least one symptom")
            return
        
        # Create feature vector
        feature_vector = pd.DataFrame(0, index=[0], columns=symptom_cols)
        for symptom in selected:
            if symptom in feature_vector.columns:
                feature_vector[symptom] = 1
        
        # Predict
        pred = rf.predict(feature_vector)[0]
        probs = rf.predict_proba(feature_vector)[0]
        
        predicted_disease = le.inverse_transform([pred])[0]
        
        # Display results
        print("\n" + "="*50)
        print("🔮 PREDICTION RESULTS")
        print("="*50)
        print(f"\n🎯 Predicted Disease: {predicted_disease.upper()}")
        print(f"📊 Confidence Score: {max(probs):.2%}")
        print(f"📋 Symptoms Analyzed: {len(selected)}\n")
        
        print("📈 Probability Distribution:")
        for i, disease in enumerate(le.classes_):
            bar_length = int(probs[i] * 30)
            bar = "█" * bar_length + "░" * (30 - bar_length)
            print(f"   {disease:25} |{bar}| {probs[i]:.1%}")
        
        # Create probability chart
        fig, ax = plt.subplots(figsize=(8, 4))
        colors = ['#FF6B6B', '#4ECDC4', '#45B7D1']
        bars = ax.bar(le.classes_, probs, color=colors, alpha=0.8)
        ax.set_ylabel('Probability')
        ax.set_title(f'Disease Probability Distribution')
        ax.set_ylim(0, 1)
        
        for bar, prob in zip(bars, probs):
            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,
                   f'{prob:.1%}', ha='center', va='bottom', fontweight='bold')
        
        plt.tight_layout()
        plt.show()

predict_button.on_click(predict_disease)
